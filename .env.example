# База даних
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=ukroverflow
DB_USER=root
DB_PASSWORD=your_secure_password_here

# API сервер
API_PORT=3338
API_HOST=localhost

# JWT
JWT_SECRET=your_jwt_secret_min_32_characters_long
JWT_EXPIRES_IN=7d

# Frontend
VITE_API_URL=http://localhost:3338
VITE_WS_URL=ws://localhost:3338

# Режим розробки
NODE_ENV=development

# Mediator
MEDIATOR_DEBUG=true
MEDIATOR_VISUALIZATION=true
MEDIATOR_LOG_LEVEL=debug

# Google Gemini AI (отримайте ключ на https://aistudio.google.com/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# Мережа / таймаут (якщо в логах "fetch failed" до generativelanguage.googleapis.com)
# GEMINI_IPv4_FIRST=0   — вимкнути пріоритет IPv4 у Node
GEMINI_REQUEST_TIMEOUT=180000
# DNS для Node (якщо ENOTFOUND generativelanguage.googleapis.com). У корп. мережі може знадобитись внутрішній DNS — тоді вкажіть його або приберіть рядок.
GEMINI_DNS_SERVERS=8.8.8.8,8.8.4.4
# Рідко: GEMINI_API_VERSION=v1

# AI Features (опціонально - можна залишити за замовчуванням)
AI_ENABLED=true
# Free tier: gemini-2.5-pro часто має limit: 0 — не викликати Pro, доки явно не увімкнете:
# AI_USE_PRO=1
# (платний план Google AI / інший ключ з квотою на Pro)
AI_MODEL_FLASH=gemini-2.5-flash
# Для платного Pro залиште gemini-2.5-pro; на free tier краще дорівняти до flash:
AI_MODEL_PRO=gemini-2.5-pro
