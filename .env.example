# База даних
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=ukroverflow
DB_USER=root
DB_PASSWORD=your_secure_password_here

# API сервер
API_PORT=3338
API_HOST=localhost

# JWT
JWT_SECRET=your_jwt_secret_min_32_characters_long
JWT_EXPIRES_IN=7d

# Frontend
VITE_API_URL=http://localhost:3338
VITE_WS_URL=ws://localhost:3338

# URL фронта (для редіректу після GitHub OAuth та CORS)
FRONTEND_URL=http://localhost:5173

# GitHub OAuth — https://github.com/settings/developers → OAuth Apps → «New OAuth App»
#
# Обовʼязково повна URL із схемою http:// або https://. У формі GitHub НЕ можна лишати лише
# «93....» без префікса — Homepage і Authorization callback відхилятимуться або не збіжаться з API.
#
# Локально (API на порту з .env API_PORT, зазвичай 3338):
#   Homepage URL: http://localhost:5173
#   Authorization callback URL: http://localhost:3338/api/auth/github/callback
#
# VPS / nginx на одному хості (HTTPS):
#   Homepage URL: https://your-domain.com
#   Authorization callback URL: https://your-domain.com/api/auth/github/callback
#   FRONTEND_URL=https://your-domain.com
#   # Найнадійніше — один рядок 1:1 як у полі Authorization callback URL у GitHub:
#   # GITHUB_OAUTH_REDIRECT_URI=https://your-domain.com/api/auth/github/callback
#
# VPS лише по IP (HTTP):
#   Homepage URL: http://YOUR_VPS_IP/
#   Authorization callback URL: http://YOUR_VPS_IP/api/auth/github/callback
#   FRONTEND_URL=http://YOUR_VPS_IP
#   GITHUB_OAUTH_REDIRECT_URI=http://YOUR_VPS_IP/api/auth/github/callback
#
# Поле OAuth App «Authorization callback URL» має дорівнювати redirect_uri бекенда
# (GET /api/auth/github/status або /api/auth/github/resolved-callback).
# На GitHub не вводьте помилково подвійний префікс (https://https://host/).
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# Явний callback (за потреби; інакше — FRONTEND_URL + /api/auth/github/callback у production тощо)
# GITHUB_OAUTH_REDIRECT_URI=http://localhost:3338/api/auth/github/callback
# GITHUB_CALLBACK_URL=http://localhost:3338/api/auth/github/callback
# PUBLIC_API_URL=https://api.example.com

# (Опційно) GitHub webhook — спільний секрет для перевірки HMAC підписів
# У GitHub repo → Settings → Webhooks → Payload URL: https://<your-tunnel>/api/github/webhook
GITHUB_WEBHOOK_SECRET=

# Режим розробки
NODE_ENV=development

# Mediator
MEDIATOR_DEBUG=true
MEDIATOR_VISUALIZATION=true
MEDIATOR_LOG_LEVEL=debug

# Google Gemini AI (отримайте ключ на https://aistudio.google.com/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# Мережа / таймаут (якщо в логах "fetch failed" до generativelanguage.googleapis.com)
# GEMINI_IPv4_FIRST=0   — вимкнути пріоритет IPv4 у Node
GEMINI_REQUEST_TIMEOUT=180000
# DNS для Node (якщо ENOTFOUND generativelanguage.googleapis.com). У корп. мережі може знадобитись внутрішній DNS — тоді вкажіть його або приберіть рядок.
GEMINI_DNS_SERVERS=8.8.8.8,8.8.4.4
# Рідко: GEMINI_API_VERSION=v1

# AI Features (опціонально - можна залишити за замовчуванням)
AI_ENABLED=true
# Free tier: gemini-2.5-pro часто має limit: 0 — не викликати Pro, доки явно не увімкнете:
# AI_USE_PRO=1
# (платний план Google AI / інший ключ з квотою на Pro)
AI_MODEL_FLASH=gemini-2.5-flash
# Для платного Pro залиште gemini-2.5-pro; на free tier краще дорівняти до flash:
AI_MODEL_PRO=gemini-2.5-pro

# Демо-сповіщення в БД: npm run seed:notifications -- --user=ВАШ_ID
# SEED_NOTIFICATIONS_USER_ID=1

# Паролі для `npm run seed` (packages/backend). Якщо не задані в dev — seed згенерує випадкові й виведе їх у кінці логу.
# SEED_ADMIN_PASSWORD=
# SEED_USER_PASSWORD=
