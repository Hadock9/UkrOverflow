{
  "name": "devflow",
  "version": "2.0.0",
  "description": "DevFlow — спільнота та knowledge hub для розробників",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "cd packages/backend && npm run dev",
    "dev:frontend": "cd packages/frontend && npm run dev",
    "build": "cd packages/frontend && npm run build",
    "migrate": "cd packages/backend && npm run migrate",
    "seed": "cd packages/backend && npm run seed",
    "seed:user": "cd packages/backend && npm run seed:user",
    "seed:communities": "cd packages/backend && npm run seed:communities",
    "seed:communities:large": "cd packages/backend && node src/scripts/seedCommunities.js --large",
    "seed:notifications": "cd packages/backend && node src/scripts/seedNotifications.js",
    "seed:news": "cd packages/backend && npm run seed:news",
    "seed:news:large": "cd packages/backend && npm run seed:news:large",
    "seed:news-poll": "cd packages/backend && npm run seed:news-poll",
    "seed:social": "cd packages/backend && node src/scripts/seedSocial.js",
    "test": "npm run test -w @ukroverflow/backend && npm run test -w frontend",
    "docker:up": "docker compose --env-file .env up -d --build",
    "docker:down": "docker compose --env-file .env down",
    "docker:logs": "docker compose --env-file .env logs -f api web"
  },
  "keywords": [
    "stackoverflow",
    "ukraine",
    "qa",
    "mediator",
    "brutalism"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
