# Build static assets; nginx serves them (same origin as /api via compose)
FROM node:22-bookworm-slim AS build
WORKDIR /app

COPY package.json package-lock.json ./
COPY packages/frontend/package.json packages/frontend/
COPY packages/shared/package.json packages/shared/
COPY packages/mediator/package.json packages/mediator/
RUN npm ci -w frontend

COPY packages/frontend ./packages/frontend
COPY packages/shared ./packages/shared
COPY packages/mediator ./packages/mediator

WORKDIR /app/packages/frontend

# Порожній VITE_API_URL = запити на той самий origin (/api через nginx)
ARG VITE_API_URL=
ARG VITE_WS_URL=
ENV VITE_API_URL=$VITE_API_URL
ENV VITE_WS_URL=$VITE_WS_URL

ARG VITE_FRONTEND_CANONICAL_ORIGIN=
ENV VITE_FRONTEND_CANONICAL_ORIGIN=$VITE_FRONTEND_CANONICAL_ORIGIN

RUN npm run build

FROM nginx:alpine
COPY deploy/nginx.conf /etc/nginx/conf.d/default.conf
COPY --from=build /app/packages/frontend/dist /usr/share/nginx/html
EXPOSE 80
