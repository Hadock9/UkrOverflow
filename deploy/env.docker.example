# Скопіюйте у корінь репозиторію як .env і підставте свої значення.
# docker compose --env-file .env up -d --build

# --- MySQL (контейнер db) ---
DB_ROOT_PASSWORD=change_me_root_password
DB_NAME=ukroverflow
DB_USER=ukroverflow
DB_PASSWORD=change_me_app_password

# Ті самі реквізити для Express (api підключається до db)
# DB_HOST і DB_PORT задаються в docker-compose.yml автоматично

# --- API ---
JWT_SECRET=change_me_to_a_secret_at_least_32_characters_long
JWT_EXPIRES_IN=7d
API_HOST=0.0.0.0
API_PORT=3338
NODE_ENV=production

# URL фронта в браузері (для CORS і OAuth redirect). Порт 80 не вказуйте:
#   FRONTEND_URL=http://localhost
# Продакшен:
#   FRONTEND_URL=https://your-domain.com
FRONTEND_URL=http://localhost

# GitHub OAuth — OAuth App: https://github.com/settings/developers
# Обов’язкові: GITHUB_CLIENT_ID, GITHUB_CLIENT_SECRET.
#
# У налаштуваннях OAuth App на GitHub:
#   Homepage URL:           https://devflow.info/
#   Authorization callback: https://devflow.info/api/auth/github/callback
# (не корінь сайту «/» — лише цей шлях до API).
# Callback у GitHub = байт у байт з redirect_uri, який віддає API (перевірка:
# curl -sk -H "Host: ваш_хост" "http://localhost:3338/api/auth/github/status" або /resolved-callback").
# У класичному OAuth App лише один callback URL; доступ і по IP, і по домену —
# два окремі OAuth Apps або GitHub App з кількома URL.
#
# --- Варіант «лише по IP» (HTTP callback без домену в GitHub) ---
# У OAuth App лише один Authorization callback URL — або https://домен/..., або http://IP/...
# Приклад IP VPS:
#   Homepage URL:           http://93.115.22.26/
#   Authorization callback: http://93.115.22.26/api/auth/github/callback
# У .env:
#   GITHUB_OAUTH_REDIRECT_URI=http://93.115.22.26/api/auth/github/callback
#   FRONTEND_URL=http://93.115.22.26
# Не задавайте GITHUB_OAUTH_PUBLIC_ORIGIN=https://devflow.info разом із IP-сценарієм — буде підміна на домен.
# Відкривайте сайт саме як http://93.115.22.26 (той самий origin, що в FRONTEND_URL).
#
# Callback у .env має збігатися з полем Authorization callback URL у GitHub
# (або fallback будується з FRONTEND_URL / PUBLIC_API_URL — див. resolveGithubCallbackUrl).
# Найнадійніше для продакшену — повний URL 1:1 як «Authorization callback URL» у GitHub OAuth App:
# GITHUB_OAUTH_REDIRECT_URI=https://devflow.info/api/auth/github/callback
#
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
# Явний callback (рекомендовано продакшен): той самий URL, що в GitHub → Authorization callback URL
GITHUB_CALLBACK_URL=http://localhost/api/auth/github/callback
# Приклад для devflow.info:
# GITHUB_CALLBACK_URL=https://devflow.info/api/auth/github/callback
# Якщо в FRONTEND_URL лише IP або немає https-домену — підміна IPv4→домен для OAuth:
# GITHUB_OAUTH_PUBLIC_ORIGIN=https://devflow.info
#
# Якщо GitHub пише «redirect_uri is not associated with this application»:
#   • Перевірте Developer settings → OAuth Apps (не GitHub Apps); Client ID має збігатися з .env.
#   • Authorization callback URL у GitHub має літерально збігатися з redirect_uri:
#       https://devflow.info/api/auth/github/callback
#     без слеша в кінці; http≠https (на проді має бути https як у OAuth App); devflow.info≠www.devflow.info.
#   • Перевірте GET https://devflow.info/api/auth/github/resolved-callback — redirect_uri має збігатися з полем у GitHub.
#   • Якщо досі підставляється http://ВАШ_IP/... — приберіть GITHUB_CALLBACK_URL і PUBLIC_API_URL на IP
#     або задайте GITHUB_CALLBACK_URL=https://devflow.info/api/auth/github/callback (як у GitHub).
#   • Якщо FRONTEND_URL через кому без GITHUB_CALLBACK_URL — redirect_uri береться з канонічного origin
#     (пріоритет https і доменне ім’я; не завжди перший у списку IP).
#
# Або база API, якщо фронт і API на різних доменах:
# PUBLIC_API_URL=https://api.example.com

GITHUB_WEBHOOK_SECRET=

# Фронт у збірці: залиште порожніми, якщо nginx і API на одному хості (compose за замовчуванням).
# Якщо API на іншому домені — укажіть повний URL (і перебудуйте web):
# VITE_API_URL=https://api.example.com
# VITE_WS_URL=wss://api.example.com/ws
VITE_API_URL=
VITE_WS_URL=

# Порт HTTP на хості (nginx)
HTTP_PORT=80

# (Опційно) AI
GEMINI_API_KEY=
AI_ENABLED=true
